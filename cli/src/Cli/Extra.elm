succeed : String -> String
succeed message =
    Ansi.Color.fontColor Ansi.Color.green "вң“ " ++ message


failed : String -> String
failed message =
    Ansi.Color.fontColor Ansi.Color.red "вЁҜ " ++ message


info : String -> String
info message =
    "рҹҰҲ  " ++ message


newLine : String
newLine =
    "\n"


appendNewLine : String -> String
appendNewLine string =
    string ++ newLine


prependNewLine : String -> String
prependNewLine =
    (++) newLine


divider : String
divider =
    "# =========================================="
